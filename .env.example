# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=Beba SACCO Backend
APP_VERSION=1.0.0

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/beba_sacco?schema=public&sslmode=require"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# Redis (Upstash)
REDIS_HOST=your-upstash-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-redis-password
REDIS_TLS=true

# Cloudflare R2 (S3-Compatible)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=beba-sacco-storage
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Tinybird Analytics
TINYBIRD_API_URL=https://api.tinybird.co
TINYBIRD_TOKEN=your-tinybird-token

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# M-Pesa Integration (Safaricom Daraja)
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SHORTCODE=174379
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=your-encrypted-credential
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
MPESA_ENVIRONMENT=sandbox

# CORS & Security
CORS_ORIGIN=http://localhost:3001,https://beba-sacco.com
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Multi-Tenancy
DEFAULT_TENANT_ID=default-tenant-uuid

