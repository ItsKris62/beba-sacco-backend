# ============================================================
#  Beba SACCO Backend – Environment Template
#  Copy this file to .env and fill in real values.
#
#  SECURITY RULES:
#   ✅ .env.example  → committed to git (this file — placeholders only)
#   ❌ .env          → NEVER committed (real dev values)
#   ❌ .env.*        → NEVER committed (real env-specific values)
#
#  Production: set vars directly in Render dashboard.
#  Never store real secrets in any file on disk in production.
# ============================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=Beba SACCO Backend
APP_VERSION=1.0.0
# Frontend base URL — used to build password reset links in emails
# Dev: http://localhost:3002 | Prod: https://your-sacco.netlify.app
APP_URL=http://localhost:3002

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# DATABASE_URL  = pooler URL  (runtime queries — PgBouncer, transaction mode)
# DIRECT_URL    = direct URL  (prisma migrate + $transaction with isolation)
#
# HOW TO GET: console.neon.tech → Project → Connection Details
#   Pooler:  ep-xxxx-pooler.REGION.aws.neon.tech
#   Direct:  ep-xxxx.REGION.aws.neon.tech  (no "-pooler")
#
# IMPORTANT: Use DIRECT_URL (not pooler) for financial transactions in production.
# See: https://neon.tech/docs/connect/connection-pooling
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64 | tr -d '\n'
# Requirements: ≥64 bytes, base64-encoded, JWT_SECRET ≠ JWT_REFRESH_SECRET
JWT_SECRET=REPLACE_WITH_64_BYTE_BASE64_SECRET
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_BASE64_SECRET
JWT_REFRESH_EXPIRATION=7d

# ── Redis (Upstash — TLS required) ───────────────────────────────────────────
# HOW TO GET: console.upstash.com → Database → Connect → ioredis
# REDIS_PASSWORD and UPSTASH_REDIS_REST_TOKEN are the same credential.
REDIS_HOST=your-db-name.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_UPSTASH_PASSWORD
REDIS_TLS=true
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_UPSTASH_REST_TOKEN

# ── Cloudflare R2 (S3-Compatible Storage) ────────────────────────────────────
# HOW TO GET: dash.cloudflare.com → R2 → Manage R2 API Tokens → Create Token
# R2_ACCOUNT_ID: dash.cloudflare.com → top-right account dropdown → "Account ID"
# R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY: from the API token creation screen
R2_ACCOUNT_ID=REPLACE_WITH_32CHAR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=sacco-docs-prod
R2_PUBLIC_URL=https://pub-REPLACE.r2.dev

# ── Tinybird Analytics ────────────────────────────────────────────────────────
# HOW TO GET: app.tinybird.co → Tokens → New Token
# Permissions needed: DATASOURCES:READ + DATASOURCES:APPEND only
TINYBIRD_TOKEN=REPLACE_WITH_TINYBIRD_API_TOKEN
TINYBIRD_API_URL=https://api.europe-west2.gcp.tinybird.co

# ── Sentry Error Tracking ─────────────────────────────────────────────────────
# HOW TO GET: sentry.io → Settings → Projects → Client Keys → DSN
# Optional in dev. Required in production (set SENTRY_ENVIRONMENT=production).
SENTRY_DSN=https://KEY@ORGID.ingest.REGION.sentry.io/PROJECTID
SENTRY_ENVIRONMENT=development

# ── M-Pesa Integration (Safaricom Daraja) ────────────────────────────────────
# Sandbox portal: https://developer.safaricom.co.ke → My Apps → Credentials
# Production portal: same, switch to "Live" tab

# OAuth credentials (from Daraja App → Credentials tab)
MPESA_CONSUMER_KEY=REPLACE_WITH_DARAJA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=REPLACE_WITH_DARAJA_CONSUMER_SECRET

# STK Push (Lipa Na M-Pesa Online)
# Sandbox shortcode: 174379 | Production: your registered paybill number
MPESA_SHORTCODE=174379
# Sandbox passkey: bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
# Production: obtain from Safaricom portal → your live paybill → Lipa Na M-Pesa → Passkey
MPESA_PASSKEY=REPLACE_WITH_MPESA_PASSKEY

# B2C (Business to Customer) — Loan disbursements
# Sandbox shortcode: 600000 | Production: your registered B2C shortcode
MPESA_B2C_SHORTCODE=600000
MPESA_INITIATOR_NAME=testapi
# Encrypted initiator password (RSA-encrypt with Safaricom cert, then base64):
# openssl rsautl -encrypt -pubin -inkey SafaricomCert.cer -in plain.txt | base64 | tr -d '\n'
MPESA_SECURITY_CREDENTIAL=REPLACE_WITH_ENCRYPTED_INITIATOR_CREDENTIAL

# Webhook / Callback URLs (must be publicly reachable HTTPS — use your Render URL)
# In dev: use ngrok for local testing only (never commit ngrok URL)
MPESA_CALLBACK_URL=https://YOUR-RENDER-SERVICE.onrender.com/api
MPESA_B2C_RESULT_URL=https://YOUR-RENDER-SERVICE.onrender.com/api/mpesa/webhooks/b2c-result
MPESA_B2C_QUEUE_TIMEOUT_URL=https://YOUR-RENDER-SERVICE.onrender.com/api/mpesa/webhooks/b2c-timeout

# Environment: sandbox | production
MPESA_ENVIRONMENT=sandbox

# HMAC-SHA256 secret for validating Safaricom callback signatures.
# Generate: openssl rand -hex 32
# Required in production (leave empty in sandbox — guard is bypassed when empty)
MPESA_WEBHOOK_SECRET=REPLACE_WITH_64CHAR_HEX_SECRET

# Comma-separated Safaricom IP allowlist for callback endpoints.
# Production IPs (verify at https://developer.safaricom.co.ke/Documentation → IPs):
MPESA_ALLOWED_IPS=196.201.214.200,196.201.214.206,196.201.213.114,196.201.214.207,196.201.214.208,196.201.213.44,196.201.214.185,196.201.214.186

# Max STK Push requests per member per calendar day (SASRA rate-control)
MPESA_STK_RATE_LIMIT_PER_DAY=3

# ── Email (Plunk Transactional) ───────────────────────────────────────────────
# HOW TO GET: app.useplunk.com → Settings → API Keys → Create API Key
# PLUNK_API_KEY starts with pk_  (public, used for sending)
# PLUNK_SECRET_KEY starts with sk_ (secret, used for webhook verification)
PLUNK_API_KEY=REPLACE_WITH_PLUNK_PUBLIC_KEY
PLUNK_SECRET_KEY=REPLACE_WITH_PLUNK_SECRET_KEY
PLUNK_FROM_EMAIL=noreply@your-sacco.co.ke
PLUNK_FROM_NAME=Beba SACCO

# ── CORS & Security ───────────────────────────────────────────────────────────
# Production: set to your Netlify domain only
# Dev: include localhost ports as needed
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,https://kolwa.netlify.app
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── Multi-Tenancy ─────────────────────────────────────────────────────────────
# UUID of the default SACCO tenant (set after first database seed)
DEFAULT_TENANT_ID=

# ── Compliance ────────────────────────────────────────────────────────────────
# Kenya Data Protection Act 2019 + SASRA: minimum 7 years audit retention
DATA_RETENTION_YEARS=7

# ── Alerting & Incident Response ─────────────────────────────────────────────
# HOW TO GET: Slack → Apps → Incoming Webhooks | PagerDuty → Services → Integrations
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/YOUR/WEBHOOK
PAGERDUTY_INTEGRATION_KEY=REPLACE_WITH_PAGERDUTY_KEY

# ── BullMQ Worker Concurrency ─────────────────────────────────────────────────
BULLMQ_CONCURRENCY_ACCRUAL=3
BULLMQ_CONCURRENCY_RECON=2
BULLMQ_CONCURRENCY_LEDGER=2
BULLMQ_CONCURRENCY_WEBHOOK=10

# ── BullMQ Queue Names (for Redis Commander / monitoring only) ────────────────
BULL_QUEUE_MPESA_CALLBACKS=mpesa-callbacks
BULL_QUEUE_MPESA_DISBURSEMENTS=mpesa-disbursements

# ── Local Development Only (NEVER set in production / Render) ─────────────────
# Ngrok: dev tunnel for local M-Pesa callback testing.
# HOW TO GET: dashboard.ngrok.com → Authtokens → New Authtoken
# Generate a fresh token per developer. Never share. Never commit actual value.
# NGROK_AUTHTOKEN=REPLACE_WITH_YOUR_OWN_DEV_NGROK_TOKEN

# Redis Commander UI (local dev only)
# REDIS_UI_USER=admin
# REDIS_UI_PASSWORD=REPLACE_WITH_LOCAL_DEV_PASSWORD

# Docker Compose local services (dev only)
# POSTGRES_USER=beba
# POSTGRES_PASSWORD=REPLACE_WITH_LOCAL_DEV_PASSWORD
# POSTGRES_DB=bebadb
# MINIO_ROOT_USER=beba_minio
# MINIO_ROOT_PASSWORD=REPLACE_WITH_LOCAL_DEV_PASSWORD
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_BUCKET=beba-backups
# MINIO_ACCESS_KEY=beba_minio
# MINIO_SECRET_KEY=REPLACE_WITH_LOCAL_DEV_PASSWORD
# BACKUP_RETENTION_DAYS=30
# BULL_BOARD_USER=admin
# BULL_BOARD_PASSWORD=REPLACE_WITH_LOCAL_DEV_PASSWORD
