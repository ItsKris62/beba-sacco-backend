# ── M-Pesa Integration (Safaricom Daraja) ─────────────────────────────────────
# Sandbox portal: https://developer.safaricom.co.ke
# Production portal: https://developer.safaricom.co.ke (live credentials)

# OAuth credentials (from Daraja app → Credentials tab)
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret

# STK Push (Lipa Na M-Pesa Online) – Paybill or Till number
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# B2C (Business to Customer) – Loan disbursements
# Sandbox default: 600000 | Production: your own B2C shortcode
MPESA_B2C_SHORTCODE=600000
MPESA_INITIATOR_NAME=testapi
# Encrypted with Safaricom public cert: openssl rsautl -encrypt -pubin -inkey SafaricomDev.pub -in plain.txt | base64
MPESA_SECURITY_CREDENTIAL=your-encrypted-initiator-password

# Webhook / Callback URLs (must be publicly reachable HTTPS in production)
# The unified callback receives STK, C2B, and B2C results
