# MinIO local dev override (leave empty for production Cloudflare R2)
# R2_ENDPOINT=http://localhost:9000

# Plunk Transactional Email
# Get your API key at https://useplunk.com → Settings → API Keys
PLUNK_API_KEY=your-plunk-api-key-here
PLUNK_FROM_EMAIL=noreply@beba-sacco.com
PLUNK_FROM_NAME=Beba SACCO

# CORS & Security
CORS_ORIGIN=http://localhost:3001,https://beba-sacco.com
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Multi-Tenancy
DEFAULT_TENANT_ID=default-tenant-uuid

# ── Docker / CI ── (used by docker-compose.prod.yml and GitHub Actions) ──────
POSTGRES_USER=beba
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=bebadb

MINIO_ROOT_USER=beba_minio
MINIO_ROOT_PASSWORD=change_me_minio_password

# GHCR image repository (e.g. your-org/beba-backend)
GITHUB_REPOSITORY=your-org/beba-backend
IMAGE_TAG=latest

# Bull Board (BullMQ queue UI) credentials
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change_me_bull_board_password



# ── Phase 4 – Financial Operations & Compliance ──────────────────────────────

# Kenya Data Protection Act: how many years to retain audit logs (default 7)
DATA_RETENTION_YEARS=7

# ── Phase 4 – Alerting & Incident Response ───────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_integration_key

# ── Phase 4 – MinIO/S3 Backups ───────────────────────────────────────────────
# MINIO_ENDPOINT is your MinIO or S3 endpoint
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=beba-backups
MINIO_ACCESS_KEY=beba_minio
MINIO_SECRET_KEY=change_me_minio_password
BACKUP_RETENTION_DAYS=30

# ── Phase 4 – BullMQ Worker Concurrency ──────────────────────────────────────
BULLMQ_CONCURRENCY_ACCRUAL=3
BULLMQ_CONCURRENCY_RECON=2
BULLMQ_CONCURRENCY_LEDGER=2
BULLMQ_CONCURRENCY_WEBHOOK=10
