MPESA_B2C_RESULT_URL=https://your-domain.com/api/mpesa/callback
MPESA_B2C_QUEUE_TIMEOUT_URL=https://your-domain.com/api/mpesa/callback

# Environment: sandbox | production
MPESA_ENVIRONMENT=sandbox

# HMAC-SHA256 secret for validating Safaricom callback signatures.
# Required in production. Generate: openssl rand -hex 32
MPESA_WEBHOOK_SECRET=

# Comma-separated Safaricom IP ranges allowed to POST to the callback endpoint.
