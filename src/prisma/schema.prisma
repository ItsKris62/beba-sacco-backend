// Beba SACCO – Multi-Tenant Database Schema
// PostgreSQL 15 + Neon + Prisma 5
//
// Multi-tenancy strategy (Phase 2 MVP):
//   "Shared schema, shared tables" – every business model carries a tenantId FK
//   and all queries are filtered by tenantId via TenantInterceptor + req.tenant.
//
//   Phase 3+ will migrate hot tables to per-tenant PostgreSQL schemas using
//   SET search_path once the DATABASE_URL is switched to the direct (non-pooler) URL.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN  // Platform admin (Beba staff)
  TENANT_ADMIN // SACCO administrator
  MANAGER      // Branch / department manager
  TELLER       // Front-office staff
  MEMBER       // Ordinary SACCO member
  AUDITOR      // Read-only compliance auditor

  @@schema("public")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  INACTIVE

  @@schema("public")
}

enum AccountType {
  BOSA // Back Office Savings Account
  FOSA // Front Office Service Account (banking)

  @@schema("public")
}

enum LoanStatus {
  DRAFT
  PENDING_GUARANTORS  // Waiting for guarantors to accept
  UNDER_REVIEW        // Guarantors confirmed; awaiting loan officer decision
  PENDING_APPROVAL    // Legacy / direct-approval path (no guarantors required)
  APPROVED
  REJECTED
  DISBURSED
  ACTIVE
  FULLY_PAID
  DEFAULTED
  WRITTEN_OFF

  @@schema("public")
}

enum GuarantorStatus {
  PENDING
  ACCEPTED
  DECLINED

  @@schema("public")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  INTEREST_EARNED
  INTEREST_ACCRUAL   // Phase 4: daily interest accrual
  PENALTY            // Phase 4: penalty charge on overdue loan
  DIVIDEND_PAYOUT
  FEE_CHARGE
  TRANSFER

  @@schema("public")
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
  RECON_PENDING // Phase 4: flagged by reconciliation engine – awaiting resolution

  @@schema("public")
}

// Phase 4: loan classification for provisioning & SASRA reporting
enum LoanStaging {
  PERFORMING  // < 30 days in arrears
  WATCHLIST   // 30–89 days in arrears
  NPL         // ≥ 90 days in arrears (Non-Performing Loan)

  @@schema("public")
}

// Phase 4: approval chain status
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED

  @@schema("public")
}

// Phase 4: webhook event subscription status
enum WebhookStatus {
  ACTIVE
  INACTIVE

  @@schema("public")
}

// Phase 4: webhook delivery status
enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED

  @@schema("public")
}

// Phase 5: Integration outbox status
enum OutboxStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  DEAD_LETTER

  @@schema("public")
}

// Phase 5: AML screening status
enum AmlScreeningStatus {
  PENDING
  CLEAR
  FLAGGED
  BLOCKED

  @@schema("public")
}

// Phase 5: CRB report status
enum CrbReportStatus {
  PENDING
  QUEUED
  SUBMITTED
  ACCEPTED
  REJECTED
  FAILED

  @@schema("public")
}

// Phase 5: DSAR request status
enum DsarRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  EXPIRED
  REDACTED

  @@schema("public")
}

// Phase 5: Notification channel
enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP

  @@schema("public")
}

// Phase 5: Notification delivery status
enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED

  @@schema("public")
}

// Phase 5: OAuth2 API client status
enum ApiClientStatus {
  ACTIVE
  SUSPENDED
  REVOKED

  @@schema("public")
}

enum InterestType {
  FLAT              // Interest on original principal
  REDUCING_BALANCE  // Interest on outstanding balance

  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// PUBLIC SCHEMA – Platform & Identity
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id           String       @id @default(uuid())
  name         String
  slug         String       @unique // e.g., "kc-boda-sacco"
  schemaName   String       @unique // reserved for Phase 3 schema routing
  status       TenantStatus @default(ACTIVE)
  settings     Json?        // SACCO config: interest rates, fee structures, etc.
  contactEmail String
  contactPhone String
  address      String?
  logoUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  auditLogs            AuditLog[]
  members              Member[]
  accounts             Account[]
  loanProducts         LoanProduct[]
  loans                Loan[]
  transactions         Transaction[]
  guarantors           Guarantor[]
  counter              TenantCounter?
  webhookSubscriptions WebhookSubscription[]

  @@index([slug])
  @@index([status])
  @@schema("public")
}

model TenantCounter {
  id         String @id @default(uuid())
  tenantId   String @unique
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  memberSeq  Int @default(0)
  accountSeq Int @default(0)
  loanSeq    Int @default(0)

  @@schema("public")
}

model User {
  id                 String   @id @default(uuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email              String   @unique
  passwordHash       String
  role               UserRole @default(MEMBER)

  firstName          String
  lastName           String
  phone              String?
  isActive           Boolean  @default(true)
  emailVerified      Boolean  @default(false)

  refreshToken       String?  @db.Text // argon2 hash of refresh JWT
  lastLoginAt        DateTime?
  mustChangePassword Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
  member    Member?

  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@schema("public")
}

model AuditLog {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     String  // e.g., "AUTH.LOGIN", "LOAN.APPROVE"
  resource   String  // e.g., "User", "Loan"
  resourceId String?

  metadata  Json?   // Snapshot of request/response
  ipAddress String?
  userAgent String?
  requestId String? @unique

  // Phase 4 – immutable audit chain: hash of this record's payload
  // prevHash links to the prior entry's hash, forming a tamper-evident chain
  prevHash String? @db.Text
  entryHash String? @db.Text

  timestamp DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS DOMAIN – Members, Accounts, Loans, Transactions
// (MVP: shared public schema + tenantId FK; Phase 3: move to per-tenant schemas)
// ─────────────────────────────────────────────────────────────────────────────

model Member {
  id           String  @id @default(uuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String  @unique // One User → one Member profile (user already scoped to one tenant)
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  memberNumber String  // Auto-generated: M-000001, M-000002 … (tenant-scoped)

  nationalId   String?
  kraPin       String?
  employer     String?
  occupation   String?
  dateOfBirth  DateTime?

  isActive     Boolean  @default(true)
  joinedAt     DateTime @default(now())

  // Phase 4 – privacy & consent (Kenya Data Protection Act)
  consentDataSharing Boolean  @default(false)
  consentUpdatedAt   DateTime?
  deletedAt          DateTime? // soft-delete for data retention

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts    Account[]
  loans       Loan[]
  guarantors  Guarantor[]

  @@unique([tenantId, memberNumber])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@schema("public")
}

model Account {
  id            String      @id @default(uuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberId      String
  member        Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)

  accountNumber String      // Auto-generated: ACC-BOSA-000001
  accountType   AccountType
  // Balance stored as Decimal(18,4) – always use Decimal class, never number
  balance       Decimal     @default(0) @db.Decimal(18, 4)
  isActive      Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@unique([tenantId, accountNumber])
  @@index([tenantId, memberId])
  @@schema("public")
}

model LoanProduct {
  id          String @id @default(uuid())
  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text

  // All monetary limits in KES, stored as Decimal(18,4)
  minAmount   Decimal @db.Decimal(18, 4)
  maxAmount   Decimal @db.Decimal(18, 4)

  // e.g., 0.1200 = 12.00 % per annum
  interestRate      Decimal      @db.Decimal(7, 4)
  interestType      InterestType @default(REDUCING_BALANCE)
  maxTenureMonths   Int
  processingFeeRate Decimal      @default(0) @db.Decimal(7, 4)

  // Grace period: months after disbursement before first repayment is due.
  // During this window interest accrues but no instalment is collected.
  // 0 = repayments start immediately in the month following disbursement.
  gracePeriodMonths Int @default(0)

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  loans Loan[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@schema("public")
}

model Loan {
  id            String      @id @default(uuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberId      String
  member        Member      @relation(fields: [memberId], references: [id])
  loanProductId String
  loanProduct   LoanProduct @relation(fields: [loanProductId], references: [id])

  loanNumber   String    // Auto-generated: LN-2025-000001
  status       LoanStatus @default(DRAFT)
  purpose      String?   @db.Text // Loan purpose stated by member

  principalAmount   Decimal @db.Decimal(18, 4)
  interestRate      Decimal @db.Decimal(7, 4) // Copied from product at application time
  processingFee     Decimal @default(0) @db.Decimal(18, 4)
  tenureMonths      Int
  gracePeriodMonths Int     @default(0)        // Copied from product at application time
  monthlyInstalment Decimal @db.Decimal(18, 4) // Pre-calculated at application (excludes grace period)

  appliedAt   DateTime  @default(now())
  approvedAt  DateTime?
  approvedBy  String?   // userId
  disbursedAt DateTime?
  disbursedBy String?   // userId
  dueDate     DateTime? // Final repayment due date

  // Repayment tracking (updated on each repayment transaction)
  totalRepaid        Decimal @default(0) @db.Decimal(18, 4)
  outstandingBalance Decimal @db.Decimal(18, 4) // = principalAmount initially, decremented on repayment

  // Phase 4 – arrears & staging (updated daily by interest-accrual job)
  arrearsAmount Decimal      @default(0) @db.Decimal(18, 4)
  arrearsDays   Int          @default(0)
  staging       LoanStaging  @default(PERFORMING)
  lastAccrualDate DateTime?  // last date interest accrual ran for this loan (idempotency)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions   Transaction[]
  guarantors     Guarantor[]
  approvalChains LoanApprovalChain[]

  @@unique([tenantId, loanNumber])
  @@index([tenantId, memberId])
  @@index([tenantId, status])
  @@index([tenantId, staging])
  @@schema("public")
}

model Guarantor {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loanId   String
  loan     Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  status          GuarantorStatus @default(PENDING)
  guaranteedAmount Decimal        @db.Decimal(18, 4)

  invitedAt   DateTime  @default(now())
  respondedAt DateTime?
  notes       String?   @db.Text // Reason for decline, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([loanId, memberId]) // A member can only guarantee a loan once
  @@index([tenantId, memberId])
  @@index([loanId])
  @@schema("public")
}

model Transaction {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  loanId String?
  loan   Loan?   @relation(fields: [loanId], references: [id])

  type          TransactionType
  status        TransactionStatus @default(PENDING)
  amount        Decimal           @db.Decimal(18, 4)
  balanceBefore Decimal           @db.Decimal(18, 4)
  balanceAfter  Decimal           @db.Decimal(18, 4)

  // Unique idempotency key – prevents double-posting
  reference   String  @unique
  description String?

  processedBy String? // userId of teller or "SYSTEM"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mpesaTransaction MpesaTransaction?

  @@index([tenantId, accountId])
  @@index([tenantId, loanId])
  @@index([reference])
  @@index([createdAt])
  @@schema("public")
}

model MpesaTransaction {
  id            String @id @default(uuid())
  tenantId      String

  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  checkoutRequestId  String  @unique
  merchantRequestId  String?
  phoneNumber        String
  amount             Decimal @db.Decimal(18, 4)

  status             TransactionStatus @default(PENDING)
  resultCode         Int?
  resultDesc         String?
  mpesaReceiptNumber String?
  callbackPayload    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([checkoutRequestId])
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 4 – Financial Operations, Compliance & Enterprise Readiness
// ─────────────────────────────────────────────────────────────────────────────

// 4-eyes principle: tracks the two required approvals for large disbursements
model LoanApprovalChain {
  id       String @id @default(uuid())
  tenantId String
  loanId   String
  loan     Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  approverId String  // userId of approver
  role       String  // role at time of approval (MANAGER / LOAN_OFFICER)
  status     ApprovalStatus @default(PENDING)
  notes      String? @db.Text

  decidedAt DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, loanId])
  @@schema("public")
}

// Device / IP fingerprinting for login sessions
model LoginSession {
  id       String @id @default(uuid())
  tenantId String
  userId   String

  ipHash    String  // SHA-256 of client IP
  userAgent String? @db.Text
  geoHint   String? // country/region hint (optional, populated from IP headers)

  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  isActive  Boolean  @default(true)

  @@index([tenantId, userId])
  @@index([ipHash])
  @@schema("public")
}

// Outbound webhook subscriptions (tenant-owned)
model WebhookSubscription {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  url       String       // Target HTTPS URL
  secret    String       // HMAC-SHA256 signing secret (stored, NOT hashed)
  events    String[]     // e.g., ["loan.status_changed", "repayment.posted"]
  status    WebhookStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@schema("public")
}

// Delivery log for each outbound webhook dispatch
model WebhookDelivery {
  id             String @id @default(uuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  event       String // e.g., "loan.status_changed"
  payload     Json
  status      WebhookDeliveryStatus @default(PENDING)
  httpStatus  Int?
  responseBody String? @db.Text
  attempts    Int      @default(0)
  nextRetryAt DateTime?

  createdAt   DateTime @default(now())
  deliveredAt DateTime?

  @@index([subscriptionId])
  @@index([status])
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 5 – Enterprise Maturity, Ecosystem Integration & SRE Excellence
// ─────────────────────────────────────────────────────────────────────────────

// Integration Outbox – guarantees at-least-once delivery for all external integrations
model IntegrationOutbox {
  id             String       @id @default(uuid())
  tenantId       String
  idempotencyKey String       @unique // Prevents duplicate processing
  integrationType String      // CRB_EXPORT | AML_SCREEN | NOTIFY | WEBHOOK
  payload        Json         // Serialized payload for the integration
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  maxAttempts    Int          @default(5)
  lastError      String?      @db.Text
  nextRetryAt    DateTime?
  processedAt    DateTime?
  deadLetteredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status, nextRetryAt])
  @@index([integrationType, status])
  @@schema("public")
}

// CRB Report – tracks CRB Africa/Metropol submissions
model CrbReport {
  id          String          @id @default(uuid())
  tenantId    String
  loanIds     String[]        // Loan UUIDs included in this report
  periodStart DateTime
  periodEnd   DateTime
  xmlPayload  String          @db.Text // Generated CRB XML
  status      CrbReportStatus @default(PENDING)
  submittedAt DateTime?
  responseCode String?
  responseMessage String?     @db.Text
  outboxId    String?         // Link to IntegrationOutbox entry

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@schema("public")
}

// AML/CFT Screening – async screening results
model AmlScreening {
  id          String             @id @default(uuid())
  tenantId    String
  memberId    String
  trigger     String             // KYC | DEPOSIT | MANUAL
  triggerRef  String?            // e.g., transaction ID for deposit triggers
  riskScore   Int?               // 0–100
  status      AmlScreeningStatus @default(PENDING)
  watchlistMatches Json?         // Array of matched entries from sanctions/PEP lists
  screenedAt  DateTime?
  reviewedBy  String?            // userId of compliance officer who reviewed
  reviewNotes String?            @db.Text
  outboxId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
  @@schema("public")
}

// IFRS 9 ECL Provisioning Entry – daily calculated expected credit loss
model ProvisioningEntry {
  id          String      @id @default(uuid())
  tenantId    String
  loanId      String
  calculationDate DateTime // Date of ECL calculation
  staging     LoanStaging // Staging at time of calculation

  // ECL = PD × LGD × EAD
  pd          Decimal     @db.Decimal(10, 6) // Probability of Default
  lgd         Decimal     @db.Decimal(10, 6) // Loss Given Default
  ead         Decimal     @db.Decimal(18, 4) // Exposure at Default
  eclAmount   Decimal     @db.Decimal(18, 4) // Calculated ECL
  macroAdjustment Decimal @default(1) @db.Decimal(7, 4) // Macro-economic adjustment factor

  createdAt DateTime @default(now())

  @@unique([tenantId, loanId, calculationDate])
  @@index([tenantId, calculationDate])
  @@index([tenantId, staging])
  @@schema("public")
}

// DSAR (Data Subject Access Request) – Kenya DPA / GDPR compliance
model DsarRequest {
  id          String            @id @default(uuid())
  tenantId    String
  memberId    String
  requestedBy String            // userId who initiated the request
  status      DsarRequestStatus @default(PENDING)
  downloadUrl String?           // Pre-signed MinIO URL for encrypted ZIP
  expiresAt   DateTime?         // URL expiry (30 days from generation)
  redactedAt  DateTime?         // When auto-redaction occurred
  auditTrail  Json?             // Tracks what data was included

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
  @@schema("public")
}

// SASRA Ratio Snapshot – historical liquidity & capital adequacy ratios
model SasraRatioSnapshot {
  id          String   @id @default(uuid())
  tenantId    String
  period      String   // YYYY-MM format
  liquidAssets        Decimal @db.Decimal(18, 4)
  shortTermLiabilities Decimal @db.Decimal(18, 4)
  liquidityRatio      Decimal @db.Decimal(10, 6)
  coreCapital         Decimal @db.Decimal(18, 4)
  totalAssets         Decimal @db.Decimal(18, 4)
  capitalAdequacyRatio Decimal @db.Decimal(10, 6)
  totalLoans          Decimal @db.Decimal(18, 4)
  nplAmount           Decimal @db.Decimal(18, 4)
  portfolioQualityRatio Decimal @db.Decimal(10, 6)
  metadata    Json?    // Additional CBK-required fields

  createdAt DateTime @default(now())

  @@unique([tenantId, period])
  @@index([tenantId])
  @@schema("public")
}

// CBK Monthly Return – versioned filing records
model CbkReturn {
  id          String   @id @default(uuid())
  tenantId    String
  period      String   // YYYY-MM format
  version     Int      @default(1)
  csvPayload  String   @db.Text // Generated CSV content
  loanPortfolio       Decimal @db.Decimal(18, 4)
  nplRatio            Decimal @db.Decimal(10, 6)
  depositGrowth       Decimal @db.Decimal(10, 6)
  capitalAdequacy     Decimal @db.Decimal(10, 6)
  filingDate  DateTime @default(now())

  createdAt DateTime @default(now())

  @@unique([tenantId, period, version])
  @@index([tenantId])
  @@schema("public")
}

// OAuth2 API Client – partner credentials for Open API Gateway
model ApiClient {
  id          String          @id @default(uuid())
  tenantId    String
  clientId    String          @unique // OAuth2 client_id
  clientSecretHash String     // Argon2 hash of client_secret
  name        String          // Partner name
  scopes      String[]        // e.g., ["read:loans", "write:deposits"]
  rateLimitTier String        @default("partner") // internal | partner | public
  status      ApiClientStatus @default(ACTIVE)
  webhookUrl  String?         // Optional webhook endpoint
  ipWhitelist String[]        // Allowed IPs (empty = all)
  lastUsedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@schema("public")
}

// Multi-channel notification log
model NotificationLog {
  id          String              @id @default(uuid())
  tenantId    String
  memberId    String?
  channel     NotificationChannel
  recipient   String              // Email, phone number, WhatsApp number
  templateId  String              // Template identifier
  payload     Json                // Template variables
  status      NotificationStatus  @default(PENDING)
  providerRef String?             // External provider reference ID
  cost        Decimal?            @db.Decimal(10, 4) // Cost in KES
  sentAt      DateTime?
  deliveredAt DateTime?
  failReason  String?             @db.Text

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
  @@index([channel, status])
  @@schema("public")
}
